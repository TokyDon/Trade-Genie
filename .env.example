# ============================================================
# TRADE GENIE - Environment Configuration
# Copy this file to .env and fill in your API keys
# ============================================================

# --- LLM Providers (at least one required) ---
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GOOGLE_GEMINI_API_KEY=your_gemini_api_key_here

# --- Data Sources ---
# NewsAPI: https://newsapi.org/register (free tier: 100 req/day)
NEWS_API_KEY=your_newsapi_key_here

# Reddit: https://www.reddit.com/prefs/apps (create a "script" app)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=TradeGenie/1.0

# Twitter/X: https://developer.twitter.com (Basic tier ~$100/mo for search)
# Leave blank to skip Twitter
TWITTER_BEARER_TOKEN=your_twitter_bearer_token

# Alpha Vantage: https://www.alphavantage.co/support/#api-key (free tier)
ALPHA_VANTAGE_API_KEY=your_alphavantage_key_here

# GDELT: No API key required (uses public data)

# --- Email (Gmail SMTP) ---
# Use an App Password, NOT your regular Gmail password
# Guide: https://support.google.com/accounts/answer/185833
GMAIL_ADDRESS=your.email@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password
EMAIL_RECIPIENTS=your.email@gmail.com,another@email.com

# --- Application Settings ---
# How often to run the full analysis (cron format)
# Daily at 7am: "0 7 * * *"
# Weekly Monday 7am: "0 7 * * 1"
SCHEDULE_DAILY=0 7 * * *
SCHEDULE_WEEKLY=0 7 * * 1

# Urgency threshold: if any event scores above this, send an immediate alert
URGENCY_SCORE_THRESHOLD=8.5

# How many top stocks/ETFs to include in each report
TOP_PICKS_COUNT=10

# Secret key for web dashboard sessions
WEB_SECRET_KEY=change-this-to-a-random-secret-string

# Optional: Password to access the web dashboard (leave blank = no auth)
WEB_DASHBOARD_PASSWORD=
